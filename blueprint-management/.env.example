# ─────────────────────────────────────────────
# Blueprint Management — environment variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://blueprint-management.com
NEXT_PUBLIC_SITE_NAME="Blueprint Management"

# --- Contact form (Resend) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# The address submissions are delivered to
CONTACT_TO_EMAIL=butlerdarin@gmail.com
# A verified sender on your Resend domain — e.g. hello@blueprint-management.com
CONTACT_FROM_EMAIL="Blueprint Management <hello@blueprint-management.com>"

# --- Google Gemini (image generation + text) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
GEMINI_TEXT_MODEL=gemini-1.5-flash-latest

# --- Apify (competitor scrape + content feeds) ---
# https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx
# Default actor IDs — override if you fork them
APIFY_WEB_SCRAPER_ACTOR=apify~web-scraper
APIFY_RSS_ACTOR=apify~rss-feed-scraper
APIFY_GOOGLE_NEWS_ACTOR=lhotanova~google-news-scraper

# --- Admin refresh endpoint ---
# Protects /api/apify and /api/gemini refresh endpoints.
# Generate with:  openssl rand -hex 32
ADMIN_REFRESH_TOKEN=change-me-to-a-long-random-string

# --- Vercel Cron (automatic) ---
# Vercel injects this header on scheduled runs. Only needed in Vercel prod;
# leave empty for local dev. Generate with:  openssl rand -hex 32
CRON_SECRET=
