# ─────────────────────────────────────────────
# Blueprint Management — environment variables (GitHub Pages build)
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://blueprint-management.com
NEXT_PUBLIC_SITE_NAME="Blueprint Management"

# --- Contact form (Web3Forms) ---
# Server-free form delivery — works on GitHub Pages.
# Sign up at https://web3forms.com with butlerdarin@gmail.com; they'll email
# you an access key. The key is safe to expose client-side — it's origin-locked.
NEXT_PUBLIC_WEB3FORMS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Apify (OPTIONAL: content feeds refresh) ---
# Only needed if you want live news populating /blog. The refresh script runs
# locally (or via GitHub Action) and commits public/cache/feeds.json.
# https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Gemini (OPTIONAL: build-time hero imagery) ---
# Only needed if you want to regenerate /public/generated/*.jpg. Unsplash
# fallbacks work without it.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXX

